            ],
            "date_published": "2018-12-11T07:54:00+01:00",
            "date_modified": "2025-11-26T11:49:17+01:00"
        },
        {
            "id": "https://graines2tech.github.io/eg-virtuel/crypter-des-mots-facilement.html",
            "url": "https://graines2tech.github.io/eg-virtuel/crypter-des-mots-facilement.html",
            "title": "Crypter des mots facilement",
            "summary": "Avec la police wingdings, chaque lettre/chiffre/accent/etc. est transformé en un symbole. Regarde ça: Donc si tu veux dire salut, ca donnera ca : Si tu l'utilise pour un mot de passe, fait attention au majuscules et minuscules.",
